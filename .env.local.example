# World of Arcane Hunters — local dev without Docker
#
# Use this when running on a machine where Docker is not available, such as a
# UTM virtual machine on Apple Silicon Mac, a plain Linux box, or CI runners
# that do not support Docker-in-Docker.
#
# To use:
#   cp .env.local.example .env
#   # Edit DATABASE_URL to your Supabase connection string (see below)
#   npm run server    # game server on :8787
#   npm run dev       # Vite client on :5173 (separate terminal)
#
# POSTGRES_PASSWORD is NOT needed here — it is only read by docker-compose.yml,
# which is not involved in this setup.
#
# WARNING: if DATABASE_URL points at your PRODUCTION Supabase project, any
# account, character, or data you create or delete during local testing is real.
# Consider creating a separate Supabase project for local/staging use, or be
# careful not to test destructive operations against production.
#
# NEVER set ALLOW_DEV_COMMANDS=1 when DATABASE_URL points at production.

# ── Database (required) ───────────────────────────────────────────────────────
# Your Supabase connection string. Use the DIRECT connection (not the pooler)
# for local dev — it supports all Postgres features the server uses.
#
# Where to find it:
#   Supabase dashboard > Settings > Database > Connection string > URI tab
#   It looks like: postgres://postgres:[password]@db.[ref].supabase.co:5432/postgres
#
DATABASE_URL=postgres://postgres:[YOUR-SUPABASE-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
#
# If the direct connection is blocked by your network (some VM NAT configs block
# port 5432), use the Session pooler instead — found under:
#   Settings > Database > Connection pooling > Session mode (port 5432)
# DATABASE_URL=postgres://postgres.[YOUR-PROJECT-REF]:[YOUR-SUPABASE-DB-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Do NOT use the Transaction pooler (port 6543) — it does not support the
# session-persistent features the server relies on.

# ── Server port ───────────────────────────────────────────────────────────────
# Default is 8787. Uncomment to override.
#PORT=8787

# ── Realm identity ────────────────────────────────────────────────────────────
# The name and type of this world shard. Shown in the realm list.
#REALM_NAME=Claudemoon
#REALM_TYPE=Normal

# ── Media cache ───────────────────────────────────────────────────────────────
# Stores content-hashed GLB and texture files between server restarts.
# The default (relative to the project root) is fine for local dev.
EASTBROOK_MEDIA_DIR=./media-cache

# ── Bot gate ──────────────────────────────────────────────────────────────────
# Leave empty for local dev — the Turnstile gate is disabled when both are unset.
# You do NOT need a Turnstile account to run the game locally.
#TURNSTILE_SECRET=
#VITE_TURNSTILE_SITEKEY=

# ── Public origin ─────────────────────────────────────────────────────────────
# Leave unset for local dev. The server falls back to the incoming request origin.
#PUBLIC_ORIGIN=https://play.yourgame.com

# ── Admin dashboard ───────────────────────────────────────────────────────────
# No config needed for local dev. The /admin path always serves the admin SPA
# regardless of hostname. Leave ADMIN_HOSTNAME unset.
#ADMIN_HOSTNAME=

# ── Restart countdown ─────────────────────────────────────────────────────────
# Only needed in production to coordinate graceful restarts. Leave empty locally.
#RESTART_COUNTDOWN_SECRET=

# ── Chat log retention ────────────────────────────────────────────────────────
#CHAT_LOG_RETENTION_DAYS=90

# ── Dev commands (E2E test bots only) ─────────────────────────────────────────
# Enables level/teleport/item cheat commands used by scripts/crypt_raid.mjs etc.
# DANGER: DO NOT uncomment this when DATABASE_URL points at your production
# Supabase project. Only safe on a dedicated dev/staging database.
#ALLOW_DEV_COMMANDS=1

# ── ElevenLabs (voice generation scripts only) ────────────────────────────────
# Only needed if you run scripts/gen_npc_voices.mjs or scripts/gen_npc_lines.mjs.
# Not read by the game server or client at runtime.
#ELEVENLABS_API_KEY=

# ── Solana / $WOC ─────────────────────────────────────────────────────────────
# Server-side only — never inlined into the client bundle.
# The public mainnet RPC is heavily rate-limited. Fine for local dev.
#SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
#WOC_MINT=3WjLscH2JsXLEFJZRA9z8ti8yRGxWGKbqymPd7UicRth

# ── Wallet UI kill switch ─────────────────────────────────────────────────────
# Set to 1 to hide the wallet-link UI in the client.
#VITE_WALLET_DISABLED=1

# ── Fork brand URLs (build-time, optional for local dev) ─────────────────────
# Only needed if you want the built client to show your real brand URLs.
# Leave unset locally — the build uses TODO- placeholder values which is fine.
#VITE_SITE_URL=https://mysite.com
#VITE_DISCORD_URL=
#VITE_DONATE_URL=
#VITE_GA_ID=
#VITE_META_PIXEL_ID=
